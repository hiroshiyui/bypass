# Build outputs / IDE state for the Android module.
# Note: .gitignore does NOT support trailing `# comments` — patterns
# must be on their own line. Comments live above the pattern.
/.gradle/
/build/
/app/build/
# Generated by the `cargoNdkBuild` Gradle task at build time.
/app/src/main/jniLibs/
# Per-machine; holds the Android SDK location.
local.properties
.idea/
*.iml
.cxx/
.kotlin/
